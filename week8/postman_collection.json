{
  "info": {
    "_postman_id": "7f6c2d89-4d6d-4db8-9f67-buoi8-demo-collection",
    "name": "Buoi 8 - API Testing Collection",
    "description": "Postman collection for Buoi 8: API Testing va Quality Assurance",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "productId",
      "value": "1"
    },
    {
      "key": "createdProductId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Response contains token\", function () {",
              "    pm.expect(jsonData.token).to.exist;",
              "    pm.expect(jsonData.token).to.be.a('string');",
              "    pm.expect(jsonData.token.length).to.be.above(0);",
              "});",
              "",
              "pm.environment.set(\"token\", jsonData.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Get All Products",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "products"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Response is an array\", function () {",
              "    pm.expect(jsonData).to.be.an('array');",
              "});",
              "",
              "pm.test(\"Products array is not empty\", function () {",
              "    pm.expect(jsonData.length).to.be.above(0);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Get Product By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/products/{{productId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "products",
            "{{productId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Response has required fields\", function () {",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.expect(jsonData).to.have.property('name');",
              "    pm.expect(jsonData).to.have.property('price');",
              "    pm.expect(jsonData).to.have.property('description');",
              "    pm.expect(jsonData).to.have.property('category');",
              "    pm.expect(jsonData).to.have.property('stock');",
              "});",
              "",
              "pm.test(\"Price is a number\", function () {",
              "    pm.expect(jsonData.price).to.be.a('number');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Create Product",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Ban phim co\",\n  \"price\": 890000,\n  \"description\": \"Mechanical keyboard\",\n  \"category\": \"Accessories\",\n  \"stock\": 12\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "products"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Response contains created product\", function () {",
              "    pm.expect(jsonData.product).to.exist;",
              "    pm.expect(jsonData.product.name).to.eql('Ban phim co');",
              "    pm.expect(jsonData.product.price).to.eql(890000);",
              "});",
              "",
              "pm.environment.set(\"createdProductId\", jsonData.product.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "5. Delete Product",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/products/{{createdProductId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "products",
            "{{createdProductId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Delete message is correct\", function () {",
              "    pm.expect(jsonData.message).to.eql('Product deleted successfully');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}